{
  "name": "maho",
  "displayName": "Maho",
  "description": "Maho Intelligence LSP integration for the Maho ecommerce platform",
  "version": "0.8.1",
  "publisher": "mahocommerce",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/mahocommerce/maho-vscode"
  },
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Programming Languages",
    "Linters",
    "Other"
  ],
  "keywords": [
    "maho",
    "ecommerce",
    "magento",
    "openmage",
    "php"
  ],
  "activationEvents": [
    "workspaceContains:maho"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "configuration": {
      "title": "Maho",
      "properties": {
        "maho.phpPath": {
          "type": "string",
          "default": "",
          "description": "Path to the PHP binary. If empty, uses `php` from PATH."
        },
        "maho.mahoPath": {
          "type": "string",
          "default": "",
          "description": "Path to the `maho` CLI. If empty, auto-detects in the workspace root."
        },
        "maho.customCommand": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "Custom command to start the LSP server (e.g. [\"docker\", \"compose\", \"exec\", \"-T\", \"php\", \"php\", \"./maho\", \"dev:lsp:start\"]). Overrides phpPath and mahoPath."
        }
      }
    }
  },
  "scripts": {
    "compile": "esbuild src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node --sourcemap",
    "watch": "esbuild src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node --sourcemap --watch",
    "package": "npm run compile && vsce package",
    "typecheck": "tsc -p ./ --noEmit"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.75.0",
    "esbuild": "^0.28.0",
    "typescript": "^5.7.0"
  }
}
